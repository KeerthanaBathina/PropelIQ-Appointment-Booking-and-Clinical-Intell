{
  "name": "extract_with_confidence",
  "description": "Extracts structured clinical entities with per-field calibrated confidence scores for consolidation confidence gating (US_046, AIR-Q07, AIR-Q08).",
  "parameters": {
    "type": "object",
    "required": ["extraction_outcome", "overall_confidence"],
    "properties": {
      "extraction_outcome": {
        "type": "string",
        "enum": ["extracted", "no-data-extracted", "unsupported-language"],
        "description": "Overall outcome of the extraction attempt."
      },
      "overall_confidence": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0,
        "description": "Aggregate confidence score for the entire extraction result."
      },
      "medications": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["drug_name", "confidence_score", "page_number", "extraction_region", "source_reference"],
          "properties": {
            "drug_name":            { "type": "string" },
            "dosage":               { "type": ["string", "null"] },
            "frequency":            { "type": ["string", "null"] },
            "route":                { "type": ["string", "null"] },
            "prescribing_physician":{ "type": ["string", "null"] },
            "prescription_date":    { "type": ["string", "null"], "description": "ISO-8601 YYYY-MM-DD; YYYY-MM or YYYY for partial dates." },
            "confidence_score":     { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0, "description": "Per-item extraction confidence; null if genuinely unassessable." },
            "source_reference":     { "type": "string", "maxLength": 200 },
            "page_number":          { "type": "integer", "minimum": 1 },
            "extraction_region":    { "type": "string" }
          }
        }
      },
      "diagnoses": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["condition_name", "confidence_score", "page_number", "extraction_region", "source_reference"],
          "properties": {
            "condition_name":    { "type": "string" },
            "icd_code":          { "type": ["string", "null"] },
            "diagnosis_date":    { "type": ["string", "null"], "description": "ISO-8601; partial dates allowed." },
            "treating_provider": { "type": ["string", "null"] },
            "status":            { "type": ["string", "null"], "enum": ["active", "resolved", "chronic", null] },
            "confidence_score":  { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 },
            "source_reference":  { "type": "string", "maxLength": 200 },
            "page_number":       { "type": "integer", "minimum": 1 },
            "extraction_region": { "type": "string" }
          }
        }
      },
      "procedures": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["procedure_name", "confidence_score", "page_number", "extraction_region", "source_reference"],
          "properties": {
            "procedure_name":       { "type": "string" },
            "procedure_date":       { "type": ["string", "null"], "description": "ISO-8601; partial dates allowed." },
            "performing_physician": { "type": ["string", "null"] },
            "facility":             { "type": ["string", "null"] },
            "cpt_code":             { "type": ["string", "null"] },
            "confidence_score":     { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 },
            "source_reference":     { "type": "string", "maxLength": 200 },
            "page_number":          { "type": "integer", "minimum": 1 },
            "extraction_region":    { "type": "string" }
          }
        }
      },
      "allergies": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["allergen", "confidence_score", "page_number", "extraction_region", "source_reference"],
          "properties": {
            "allergen":          { "type": "string" },
            "reaction_type":     { "type": ["string", "null"] },
            "severity":          { "type": ["string", "null"], "enum": ["mild", "moderate", "severe", "life-threatening", null] },
            "onset_date":        { "type": ["string", "null"], "description": "ISO-8601; partial dates allowed." },
            "status":            { "type": ["string", "null"], "enum": ["active", "inactive", null] },
            "confidence_score":  { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 },
            "source_reference":  { "type": "string", "maxLength": 200 },
            "page_number":       { "type": "integer", "minimum": 1 },
            "extraction_region": { "type": "string" }
          }
        }
      }
    }
  }
}
