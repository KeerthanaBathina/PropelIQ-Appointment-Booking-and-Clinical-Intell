{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=upacip;Username=upacip_app;Password=REPLACE_WITH_SECRET;Maximum Pool Size=100;Timeout=30"
  },
  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=False,ssl=False"
  },
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173" ]
  },
  "EmailProvider": {
    "DeliveryTimeoutSeconds": 30,
    "MaxRetryAttempts": 3,
    "EnableFallback": false,
    "Primary": {
      "ProviderName": "SendGrid",
      "Host": "smtp.sendgrid.net",
      "Port": 587,
      "Username": "apikey",
      "Password": "REPLACE_WITH_SECRET",
      "FromAddress": "noreply@upacip.clinic",
      "FromName": "UPACIP Medical (Dev)",
      "DailyQuotaLimit": 100
    }
  },
  "SmsProvider": {
    "AccountSid": "REPLACE_WITH_SECRET",
    "AuthToken": "REPLACE_WITH_SECRET",
    "FromNumber": "REPLACE_WITH_TWILIO_PHONE_NUMBER",
    "DeliveryTimeoutSeconds": 30,
    "MaxRetryAttempts": 3,
    "SmsEnabled": false,
    "AllowedCountryCode": "+1"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://localhost:5000" },
      "Https": {
        "Url": "https://localhost:5001",
        "Certificate": {
          "Path": "",
          "Password": ""
        }
      }
    }
  }
}
