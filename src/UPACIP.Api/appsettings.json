{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=upacip;Username=upacip_app;Password=REPLACE_WITH_SECRET;Maximum Pool Size=100;Timeout=30"
  },
  "Redis": {
    "ConnectionString": "{upstash-endpoint}:{port},password=REPLACE_WITH_SECRET,ssl=True,abortConnect=False"
  },
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      },
      "Https": {
        "Url": "https://localhost:5001",
        "Certificate": {
          "Path": "C:\\Certificates\\upacip.pfx",
          "Password": "REPLACE_WITH_SECRET"
        }
      }
    }
  },
  "JwtSettings": {
    "Issuer": "upacip-api",
    "Audience": "upacip-clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "FeatureManagement": {
    "AiDocumentParsing": false,
    "SmsNotifications": false,
    "ConversationalIntake": false,
    "WaitlistManagement": true
  },
  "AiGateway": {
    "OpenAiApiKey": "REPLACE_WITH_SECRET",
    "OpenAiModel": "gpt-4o-mini",
    "OpenAiBaseUrl": "https://api.openai.com",
    "AnthropicApiKey": "REPLACE_WITH_SECRET",
    "AnthropicModel": "claude-3-5-sonnet-20241022",
    "AnthropicBaseUrl": "https://api.anthropic.com",
    "TimeoutSeconds": 10
  },
  "ClinicSettings": {
    "Name": "UPACIP Medical Clinic",
    "TimeZoneId": "America/New_York",
    "Domain": "upacip.clinic",
    "PortalBaseUrl": "https://portal.upacip.clinic"
  },
  "EmailProvider": {
    "DeliveryTimeoutSeconds": 30,
    "MaxRetryAttempts": 3,
    "EnableFallback": true,
    "Primary": {
      "ProviderName": "SendGrid",
      "Host": "smtp.sendgrid.net",
      "Port": 587,
      "Username": "apikey",
      "Password": "REPLACE_WITH_SECRET",
      "FromAddress": "noreply@upacip.clinic",
      "FromName": "UPACIP Medical",
      "DailyQuotaLimit": 100
    },
    "Fallback": {
      "ProviderName": "Gmail",
      "Host": "smtp.gmail.com",
      "Port": 587,
      "Username": "REPLACE_WITH_GMAIL_ADDRESS",
      "Password": "REPLACE_WITH_SECRET",
      "FromAddress": "REPLACE_WITH_GMAIL_ADDRESS",
      "FromName": "UPACIP Medical",
      "DailyQuotaLimit": 0
    }
  },
  "SmsProvider": {
    "AccountSid": "REPLACE_WITH_SECRET",
    "AuthToken": "REPLACE_WITH_SECRET",
    "FromNumber": "REPLACE_WITH_TWILIO_PHONE_NUMBER",
    "DeliveryTimeoutSeconds": 30,
    "MaxRetryAttempts": 3,
    "SmsEnabled": true,
    "AllowedCountryCode": "+1"
  },
  "DocumentStorage": {
    "StoragePath": "C:\\UploadedDocuments",
    "EncryptionKeyBase64": "REPLACE_WITH_BASE64_ENCODED_32_BYTE_AES256_KEY"
  },
  "DocumentParsing": {
    "MaxConcurrentJobs": 5,
    "PollingIntervalSeconds": 5,
    "MaxRetryAttempts": 3
  }
}
