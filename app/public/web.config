<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!--
      IIS URL Rewrite rules for React SPA (client-side routing).
      All requests that do NOT map to an existing physical file or directory
      are rewritten to /index.html so React Router can handle the route.
      Requires the IIS URL Rewrite module: https://www.iis.net/downloads/microsoft/url-rewrite
    -->
    <rewrite>
      <rules>
        <rule name="SPA Client-Side Routing" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <!-- Pass through requests for physical files (JS, CSS, images, etc.) -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <!-- Pass through requests for physical directories -->
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Serve pre-compressed assets when available -->
    <staticContent>
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
    </staticContent>

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
